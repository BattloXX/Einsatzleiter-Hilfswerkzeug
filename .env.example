# ─── Datenbank ────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://einsatzleiter:PASSWORT@127.0.0.1:3306/einsatzleiter

# ─── Session / Sicherheit ─────────────────────────────────────────────
# Pflicht: min. 32 Zeichen, langer zufälliger String. Erzeugen z.B. mit:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SESSION_MAX_AGE_SECONDS=86400
SESSION_INACTIVITY_SECONDS=28800
# In Produktion (HTTPS) auf true
COOKIE_SECURE=false

# ─── App ──────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8092
APP_BASE_URL=https://einsatzcockpit.com
# Öffentliche URL für Mail-Links (Passwort-Reset etc.). Leer = APP_BASE_URL
PUBLIC_BASE_URL=
DEBUG=false
# Testsystem-Modus: Zeigt einen deutlichen "TEST SYSTEM" Hinweis im Header und auf Ausdrucken
TEST_SYSTEM=false

# ─── Web Push (VAPID) ─────────────────────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com

# ─── Erster Admin (nur beim ersten Start ausgewertet) ─────────────────
# Wenn BOOTSTRAP_ADMIN_PASSWORD leer ist, wird beim ersten Start ein
# zufälliges Passwort generiert und einmalig in den Log geschrieben.
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=

# ─── PDF ──────────────────────────────────────────────────────────────
PDF_LOGO_PATH=app/static/img/logo.png

# ─── SMTP / Mail (für Passwort-Reset) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=einsatzleiter@feuerwehr-wolfurt.at
SMTP_STARTTLS=true
SMTP_TIMEOUT=15
PASSWORD_RESET_TTL_MIN=30

# ─── Login-Lockout ────────────────────────────────────────────────────
LOGIN_MAX_FAILED=5
LOGIN_LOCKOUT_MINUTES=15

# ─── Fernet-Verschlüsselung ───────────────────────────────────────────
# Empfohlen: eigenen Key setzen, unabhängig von SECRET_KEY rotierbar.
# Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leer = Fallback auf SHA256(SECRET_KEY) [abwärtskompatibel].
FERNET_KEY=

# ─── SSO / Microsoft Entra ID ────────────────────────────────────────
# Globaler Killswitch. Verbindungsdaten (Tenant ID, Client ID, Secret)
# werden je Organisation im Tool selbst unter Admin -> SSO konfiguriert.
SSO_ENABLED=true
# MS_LOGIN_BASE_URL=https://login.microsoftonline.com  # nur für Sovereign Clouds ändern
# SSO_HTTP_TIMEOUT=10
# SSO_FLOW_MAX_AGE=600
# SSO_JWKS_CACHE_TTL=3600

# ─── In-App-Update-Mechanismus ────────────────────────────────────────
# Wenn true, muss beim ZIP-Upload der SHA256 des Releases angegeben werden
UPDATE_ZIP_REQUIRE_HASH=true

# ─── KI-Integration (Anthropic Claude) ───────────────────────────────────
# Aktivierung: AI_ENABLED=true + gültiger API-Key → KI-Funktionen sichtbar.
# Standardmäßig deaktiviert; bewusst pro Instanz einschalten.
ANTHROPIC_API_KEY=
AI_ENABLED=false
AI_MODEL_DEFAULT=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MAX_TOKENS=1500
AI_TIMEOUT=20

# ─── Firebase Cloud Messaging (native Android Push) ───────────────────
# FCM_ENABLED=true aktiviert den zweiten Push-Kanal neben VAPID.
# FCM_PROJECT_ID: Firebase Project-ID (z.B. "einsatzleiter-12345")
# FCM_CREDENTIALS_PATH: Absoluter Pfad zur Service-Account-JSON ausserhalb des Repos
FCM_ENABLED=false
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=/etc/einsatzleiter/fcm-service-account.json

# ─── Lokale Wetterstation (Davis Vantage Pro 2 / Meteobridge) ──────────
# Separate DB fuer die Zeitreihe (eigener Pool, damit Einsatz-Funktionen Vorrang
# behalten und die operative DB nicht aufgeblaeht wird). Leer = Feature deaktiviert.
WEATHER_DATABASE_URL=mysql+pymysql://einsatzleiter:PASSWORT@127.0.0.1:3306/einsatzleiter_weather
# Ingest-Endpoint (Meteobridge-Push) global aktiv
WEATHER_STATION_INGEST_ENABLED=true
# Aufbewahrungsdauer der historischen Messwerte in Tagen (taegliche Loeschung)
WEATHER_READING_RETENTION_DAYS=365
# Mindestabstand zwischen zwei akzeptierten Pushes je Station (Sekunden)
WEATHER_INGEST_MIN_INTERVAL_S=60
